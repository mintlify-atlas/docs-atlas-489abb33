{
  "projectType": "saas",
  "projectName": "TravelConnect",
  "projectDescription": "A full-stack travel social platform that lets users discover, join, and chat about trips, with role-based access for travelers, trip creators, and administrators.",
  "theme": "almond",
  "primaryColor": "#1A73E8",
  "lightColor": "#E8F4FD",
  "darkColor": "#0D47A1",
