  },
  "keyFeatures": [
    "Role-based access control with Viatger (Traveler), Creador (Creator), and Admin roles",
    "Trip discovery and enrollment — browse available trips and join with one click",
    "Real-time trip chat — group messaging per trip for all enrolled participants",
    "Trip creation and management — Creators can create, edit, and manage trip details",
    "Promotion request system — Travelers can request to be promoted to trip creators",
    "Admin panel — manage users, roles, and handle promotion requests",
    "JWT authentication with persistent sessions via localStorage",
    "Protected routes enforcing role-based UI navigation"
  ],
  "publicApiSurface": [
    "POST /auth/login",
    "POST /auth/register",
    "GET /users/me",
    "PUT /users/me/{nom}/{bio}",
    "GET /viatge/trips",
    "GET /viatge/trips/{id}",
    "POST /viatge/trips/{id}/enroll",
    "POST /viatge/trips/{id}/leave",
    "POST /viatge/promote-request",
    "POST /creadorViatges/creator/trips",
    "PUT /creadorViatges/creator/trips/{id}",
    "GET /missatges/trips/{trip_id}/chat",
    "POST /missatges/trips/{trip_id}/chat/send",
    "GET /admin/users",
    "PUT /admin/users/{user_id}/promote",
    "GET /admin/users/promotions",
    "PUT /admin/promotions/{user_id}"
  ]
}
